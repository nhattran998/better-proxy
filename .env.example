# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_DATA_PATH=./volumes

# Auth - Basic
JWT_SECRET=change-this-to-random-32-chars-minimum

# Auth - OIDC (Keycloak) - Self-hosted
OIDC_ENABLED=true
KEYCLOAK_URL=https://keycloak.your-domain.com
KEYCLOAK_REALM=proxy-agent
OIDC_CLIENT_ID=proxy-agent
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/oidc/callback

# RTK & Caveman
RTK_ENABLED=true
CAVEMAN_ENABLED=false
CAVEMAN_LEVEL=full

# MITM Proxy
MITM_ENABLED=false
MITM_PORT=8443
MITM_CA_PATH=./volumes/ca

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Providers (optional - can also be configured via dashboard)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# GLM_API_KEY=...
